{
  "name": "top5",
  "version": "1.102.1",
  "description": "Focus management app - limit yourself to 5 projects",
  "license": "MIT WITH Commons-Clause",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "find src -name '*.js' -not -name 'electron.vite.config.js' -delete && rm -f tsconfig.node.tsbuildinfo tsconfig.web.tsbuildinfo",
    "test": "rm -rf .tmp-tests && tsc -p tsconfig.tests.json && node --test '.tmp-tests/tests/schedule.test.js' '.tmp-tests/tests/filename.test.js' '.tmp-tests/tests/habit-schedule.test.js' && rm -rf .tmp-tests",
    "test:api": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --build",
    "build": "npm run clean && npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "postcss": "^8.5.10"
  }
}
