{
  "name": "top5",
  "version": "1.55.1",
  "description": "Focus management app - limit yourself to 5 projects",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "find src -name '*.js' -not -name 'electron.vite.config.js' -delete && rm -f tsconfig.node.tsbuildinfo tsconfig.web.tsbuildinfo",
    "test": "rm -rf .tmp-tests && tsc -p tsconfig.tests.json && node --test .tmp-tests/tests && rm -rf .tmp-tests",
    "test:api": "vitest run",
    "typecheck": "tsc --build",
    "build": "npm run clean && npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.29.1",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^4.0.18"
  }
}
